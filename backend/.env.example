# ============================================================================
# Trigger (Trading Journal) - Environment Configuration
# ============================================================================

# -----------------------------------------------------------------------------
# Personal Supabase Database (Read/Write)
# Your trading data: positions, trades, journal, principles
# -----------------------------------------------------------------------------
PERSONAL_SUPABASE_URL=https://your-project.supabase.co
PERSONAL_SUPABASE_KEY=your-anon-key-here

# Alternative: Store in macOS Keychain
# Service: supabase-trading-journal, Account: url
# Service: supabase-trading-journal-anon, Account: trading-journal

# -----------------------------------------------------------------------------
# Arete Supabase Database (Read Only)
# Market data and research context only
# -----------------------------------------------------------------------------
ARETE_SUPABASE_URL=https://goptgqfllyutklnyjvoj.supabase.co
# Key stored in Keychain: supabase-arete-anon / arete

# -----------------------------------------------------------------------------
# Allowed Arete Tables (READ ONLY)
# DO NOT query any table not on this list!
# -----------------------------------------------------------------------------
# Price Data:
#   - cmc_asset_data (crypto prices)
#   - stock_ohlcv (stocks, commodities, ETFs)
#
# Research Context:
#   - notes
#   - theses
#   - predictions
#   - note_topics
#   - note_links

# -----------------------------------------------------------------------------
# AI Configuration (for Coach feature)
# -----------------------------------------------------------------------------
# OpenClaw Gateway (recommended)
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# OR direct API (fallback)
ANTHROPIC_API_KEY=your-api-key

# -----------------------------------------------------------------------------
# App Settings
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
