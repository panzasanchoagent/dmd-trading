# Backend API (FastAPI)
# Prefer API_URL because rewrites run server-side. NEXT_PUBLIC_API_URL is only a fallback.
# You can set either the backend origin (http://host:8001) or a full API base (https://host/app/api).
# For the Mac mini setup, stale NEXT_PUBLIC_API_URL Tailscale hosts (100.x.x.x:8001) are normalized back to localhost.
# If you truly need a remote backend host, set API_URL explicitly.
API_URL=http://127.0.0.1:8001
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001

# Personal Supabase (for client-side if needed)
NEXT_PUBLIC_PERSONAL_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_PERSONAL_SUPABASE_ANON_KEY=your-anon-key

# Arete Supabase (read-only access for context)
NEXT_PUBLIC_ARETE_SUPABASE_URL=https://goptgqfllyutklnyjvoj.supabase.co
NEXT_PUBLIC_ARETE_SUPABASE_ANON_KEY=your-arete-anon-key
